# Environment variables for the project
# Optional: Set these values to customize the app
NEXT_PUBLIC_APP_TITLE=MixMaster
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Base URL for the CocktailDB API
NEXT_PUBLIC_API_BASE_URL=https://www.thecocktaildb.com/api/json/v1/1

# Resend (newsletter email delivery)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=MixMaster <newsletter@your-domain.com>
RESEND_REPLY_TO_EMAIL=contact@your-domain.com

# Upstash Redis (newsletter subscriber storage)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Security key used to sign one-click unsubscribe links
NEWSLETTER_UNSUBSCRIBE_SECRET=replace_with_a_long_random_secret

# Optional: separate signing key for double opt-in confirmation links
NEWSLETTER_CONFIRM_SECRET=replace_with_another_long_random_secret

# Access key for admin control room route
ADMIN_DASHBOARD_KEY=replace_with_strong_admin_key
ADMIN_SESSION_SECRET=replace_with_strong_session_secret

# Secret for protected weekly digest trigger route
CRON_DIGEST_SECRET=replace_with_cron_secret
